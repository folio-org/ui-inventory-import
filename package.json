{
  "name": "@folio/inventory-import",
  "version": "4.0.0",
  "description": "Admin console for the Index Data Harvester",
  "repository": "https://github.com/folio-org/ui-inventory-import",
  "license": "Apache-2.0",
  "main": "src/index.js",
  "scripts": {
    "start": "stripes serve --startProxy --port 3003 --okapi https://snapshot-dev-okapi.folio-dev.indexdata.com --tenant harvester",
    "test": "env DEBUG_PRINT_LIMIT=100000 jest --coverage --verbose",
    "lint": "eslint -f unix .",
    "qlint": "eslint -f unix  --rule '{\"no-console\":\"off\"}' .",
    "build-mod-descriptor": "stripes mod descriptor --full --strict | jq '.[]' > module-descriptor.json",
    "formatjs-compile": "formatjs compile-folder --ast --format simple ./translations/ui-inventory-import ./translations/ui-inventory-import/compiled"
  },
  "stripes": {
    "actsAs": [
      "app",
      "settings"
    ],
    "displayName": "ui-inventory-import.meta.title",
    "route": "/invimp",
    "queryResource": "query",
    "icons": [
      {
        "name": "app",
        "alt": "Admin console for the Index Data Harvester",
        "title": "Harvester admin"
      }
    ],
    "okapiInterfaces": {
      "inventory-import": "1.0"
    },
    "optionalOkapiInterfaces": {
    },
    "permissionSets": [
      {
        "permissionName": "module.inventory-import.enabled",
        "displayName": "UI: Inventory import module is enabled",
        "subPermissions": [
          "stripes-core.settings.read"
        ],
        "visible": false
      },
      {
        "permissionName": "settings.inventory-import.enabled",
        "displayName": "Settings (Inventory import): display list of settings pages",
        "subPermissions": [
          "stripes-core.settings.read",
          "settings.enabled"
        ],
        "visible": false
      },
      {
        "permissionName": "ui-inventory-import.settings.view",
        "displayName": "Inventory import (Settings): View transformation pipelines, transformation steps, channels and log-file deletion threshold",
        "subPermissions": [
          "settings.inventory-import.enabled",
          "mod-settings.entries.collection.get",
          "inventory-update.import.steps.collection.get",
          "inventory-update.import.steps.item.get",
          "inventory-update.import.transformations.collection.get",
          "inventory-update.import.transformations.item.get",
	  "inventory-update.import.channels.collection.get",
	  "inventory-update.import.channels.item.get",
          "mod-settings.global.read.mod-inventory-update"
        ],
        "visible": true
      },
      {
        "permissionName": "ui-inventory-import.settings.view-edit",
        "displayName": "Inventory import (Settings): View, edit transformation pipelines, transformation steps, channels and log-file deletion threshold",
        "subPermissions": [
          "ui-inventory-import.settings.view",
          "mod-settings.entries.item.put",
          "mod-settings.entries.item.post",
          "inventory-update.import.steps.item.put",
          "inventory-update.import.transformations.item.put",
	  "inventory-update.import.channels.item.put",
          "mod-settings.global.write.mod-inventory-update"
        ],
        "visible": true
      },
      {
        "permissionName": "ui-inventory-import.settings.view-edit-create",
        "displayName": "Inventory import (Settings): View, edit, create transformation pipelines, transformation steps and channels",
        "subPermissions": [
          "ui-inventory-import.settings.view-edit",
          "inventory-update.import.steps.item.post",
          "inventory-update.import.transformations.item.post",
	  "inventory-update.import.channels.item.post"
        ],
        "visible": true
      },
      {
        "permissionName": "ui-inventory-import.settings.view-edit-create-delete",
        "displayName": "Inventory import (Settings): View, edit, create, delete transformation pipelines, transformation steps and channels",
        "subPermissions": [
          "ui-inventory-import.settings.view-edit-create",
          "inventory-update.import.steps.item.delete",
          "inventory-update.import.transformations.item.delete",
	  "inventory-update.import.channels.item.delete"
        ],
        "visible": true
      },
      {
        "permissionName": "ui-inventory-import.channels.get",
        "displayName": "Inventory import: View channels",
        "subPermissions": [
          "module.inventory-import.enabled",
	  "inventory-update.import.channels.collection.get",
	  "inventory-update.import.channels.item.get"
        ],
        "visible": true
      },
      {
        "permissionName": "ui-inventory-import.channels.put",
        "displayName": "Inventory import: View, edit channels",
        "subPermissions": [
          "ui-inventory-import.channels.get",
   	  "inventory-update.import.channels.item.put",
	  "inventory-update.import.transformations.collection.get"
        ],
        "visible": true
      },
      {
        "permissionName": "ui-inventory-import.channels.post",
        "displayName": "Inventory import: View, edit, create channels",
        "subPermissions": [
          "ui-inventory-import.channels.put",
   	  "inventory-update.import.channels.item.post"
        ],
        "visible": true
      },
      {
        "permissionName": "ui-inventory-import.channels.delete",
        "displayName": "Inventory import: View, edit, create, delete channels",
        "subPermissions": [
          "ui-inventory-import.channels.post",
   	  "inventory-update.import.channels.item.delete"
        ],
        "visible": true
      },
      {
        "permissionName": "ui-inventory-import.jobs-and-failed-records.get",
        "displayName": "Inventory import: View jobs and failed records",
        "subPermissions": [
          "module.inventory-import.enabled",
	  "inventory-update.import.import-jobs.collection.get",
	  "inventory-update.import.import-jobs.item.get",
          "inventory-update.import.job-logs.collection.get",
	  "inventory-update.import.failed-records.collection.get",
	  "inventory-update.import.failed-records.item.get"
        ],
        "visible": true
      },
      {
        "permissionName": "ui-inventory-import.all",
        "displayName": "Inventory import: All permissions",
        "subPermissions": [
          "ui-inventory-import.settings.view-edit-create-delete",
          "ui-inventory-import.channels.delete",
          "ui-inventory-import.jobs-and-failed-records.get"
        ],
        "visible": true
      }
    ]
  },
  "dependencies": {
    "final-form-arrays": "^3.0.2",
    "final-form-set-field-data": "^1.0.2",
    "lodash": "^4.17.0",
    "prop-types": "^15.5.10",
    "query-string": "^6.0.0",
    "react-final-form": "^6.3.0",
    "react-final-form-arrays": "^3.1.3",
    "react-inspector": "^6.0.0",
    "use-deep-compare": "^1.1.0"
  },
  "peerDependencies": {
    "@folio/stripes": "^10.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intl": "^7.1.5",
    "react-router": "*",
    "react-router-dom": "*"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.15.0",
    "@folio/eslint-config-stripes": "^8.0.0",
    "@folio/jest-config-stripes": "^3.0.0",
    "@folio/stripes": "^10.0.0",
    "@folio/stripes-cli": "^4.0.0",
    "@formatjs/cli": "^4.2.20",
    "eslint": "^7.32.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "history": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-intl": "^7.1.5",
    "react-router": "^5.2.0",
    "react-router-dom": "^5.2.0"
  }
}
